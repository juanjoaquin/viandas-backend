Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoiNjQ0MjJhODEtNTNhNi00NmMwLWJiYTEtNTY0NzllYjg5NGFjIiwiZW1haWwiOiJhZG1pbkBhZG1pbi5jb20iLCJyb2xlIjoiQURNSU4iLCJleHAiOjE3ODE1NDUzMTcsImlhdCI6MTc4MTQ1ODkxN30.ymKnjLlz4v67hDzUd6Sn-Z5lcG1bUMgl1pYjjpj1M1k

###

### Actualizar cliente (ADMIN)
PUT {{baseUrl}}/customers/{{customerId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Empresa A Actualizada",
  "type": "COMPANY",
  "phone": "999888777",
  "address": "Nueva dirección 789"
}

###

### Eliminar cliente (ADMIN)
DELETE {{baseUrl}}/customers/{{customerId}}
Authorization: Bearer {{token}}

###
